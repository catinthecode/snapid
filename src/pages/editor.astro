---
import Layout from '../layouts/Layout.astro';
import EditorPage from '../components/EditorPage';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Passport Photo Editor" description="Crop your photo to exact passport dimensions with country-specific face guidelines.">
  <EditorPage client:only="react" base={base} />
</Layout>
