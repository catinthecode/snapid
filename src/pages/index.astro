---
import Layout from '../layouts/Layout.astro';

const APP_NAME = 'PassPhoto';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [
  'USA', 'Canada', 'UK', 'Australia', 'Schengen', 'India',
  'China', 'Japan', 'South Korea', 'Brazil', 'Mexico', 'Russia',
  'Taiwan', 'Finland (Print)', 'Finland (Digital)',
];


---
<Layout title="Free ID Photo Maker Online">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-50 to-blue-100 py-20 px-4">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1 space-y-6">
        <h1 class="text-5xl font-bold tracking-tight">
          <span class="text-indigo-600">{APP_NAME}</span> — ID Photo Maker
        </h1>
        <p class="text-xl text-gray-600">
          Create compliant passport and ID photos in seconds, right from your browser.
          Free, private, no sign-up required.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={`${base}/editor`} class="px-6 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 transition-colors shadow">
            Start Editing
          </a>
        </div>
        <div class="flex flex-wrap gap-4 text-sm text-gray-600 pt-2">
          {['Instant Processing', '100% Free', 'No Sign-Up', 'No Watermarks'].map(t => (
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4 text-indigo-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              {t}
            </span>
          ))}
        </div>
      </div>
      <div class="flex-1 flex justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-4 w-72">
          <div class="bg-gray-100 rounded-xl aspect-[35/45] flex items-center justify-center text-gray-400">
            <svg class="w-16 h-16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          </div>
          <div class="mt-3 text-center text-xs text-gray-500">Preview — USA 2×2 inch</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works + Features -->
  <section class="py-12 px-4 border-t border-gray-100">
    <div class="max-w-5xl mx-auto space-y-10">

      <div class="flex flex-col sm:flex-row gap-2 sm:gap-8 sm:items-baseline">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 shrink-0 w-28">How it works</p>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm text-gray-600">
          {[
            { n: '1', title: 'Upload', desc: 'Any portrait photo — JPEG, PNG, or WEBP.' },
            { n: '2', title: 'Crop', desc: 'Pan and zoom within the country-specific face guide.' },
            { n: '3', title: 'Download', desc: 'Single photo or a print-ready 4×6 sheet.' },
          ].map(s => (
            <div class="flex items-start gap-2">
              <span class="text-indigo-400 font-bold tabular-nums">{s.n}.</span>
              <span><span class="font-medium text-gray-700">{s.title}</span> — {s.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-2 sm:gap-8 sm:items-baseline">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 shrink-0 w-28">Includes</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-600">
          {[
            'AI background removal (in-browser)',
            'Country-specific face guides',
            '15 country formats',
            'Print-ready 4×6 sheet',
            'No sign-up or watermarks',
            'Photos never leave your device',
          ].map(f => (
            <span class="flex items-center gap-1.5">
              <span class="w-1 h-1 rounded-full bg-indigo-400 inline-block"></span>
              {f}
            </span>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Countries -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-3">Supported Countries</h2>
      <p class="text-gray-500 mb-8">Correct dimensions and face guidelines for every country</p>
      <div class="flex flex-wrap justify-center gap-2">
        {countries.map(c => (
          <span class="px-3 py-1 bg-indigo-100 text-indigo-800 rounded-full text-sm font-medium">{c}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 bg-gradient-to-r from-indigo-600 to-blue-600">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h2 class="text-3xl font-bold mb-3">Ready to create your ID photo?</h2>
      <p class="text-indigo-100 mb-6">It only takes a minute to get a professional result.</p>
      <a href={`${base}/editor`} class="inline-block px-8 py-3 bg-white text-indigo-700 font-semibold rounded-lg hover:bg-indigo-50 transition-colors shadow">
        Start Editing — It's Free
      </a>
    </div>
  </section>
</Layout>
