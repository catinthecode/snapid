---
import Layout from '../layouts/Layout.astro';
import BgRemovePage from '../components/BgRemovePage';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Remove Photo Background" description="Free AI background removal — runs entirely in your browser. No upload to any server.">
  <BgRemovePage client:only="react" base={base} />
</Layout>
