---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Free Passport Photo Maker Online',
  description = 'Create compliant passport photos in seconds, right from your browser. Free AI background removal. No sign-up required.',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | PassPhoto</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 flex flex-col">
    <header class="bg-white border-b sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href={`${base}/`} class="flex items-center gap-2 font-bold text-xl text-indigo-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
          PassPhoto
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a href={`${base}/editor`} class="px-4 py-1.5 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 transition-colors font-medium">Start Editing</a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="bg-white border-t py-6 mt-auto">
      <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-gray-500">
        <span>© 2026 PassPhoto. All rights reserved.</span>
        <div class="flex gap-4">
          <a href={`${base}/privacy-policy`} class="hover:text-green-600">Privacy Policy</a>
          <a href={`${base}/terms`} class="hover:text-green-600">Terms of Service</a>
        </div>
      </div>
    </footer>
  </body>
</html>
